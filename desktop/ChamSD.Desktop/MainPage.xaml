<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="ChamSD_Desktop.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:ChamSD_Desktop"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid
        x:Name="RootGrid"
        Background="#F5F7FA"
        Padding="14"
        RowSpacing="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
                <Border
                    x:Name="StatusBar"
                    Padding="18,14"
                    Background="#FFF7E0"
                    BorderBrush="#E5B21F"
                    BorderThickness="1"
                    CornerRadius="8"
                    RenderTransformOrigin="0.5,0.5">
                    <Border.RenderTransform>
                        <CompositeTransform x:Name="StatusBarTransform" />
                    </Border.RenderTransform>
                    <Grid ColumnSpacing="16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Spacing="4">
                            <TextBlock
                                x:Name="StatusText"
                                FontSize="24"
                                FontWeight="SemiBold"
                                Text="STATUS: LOADING" />
                            <TextBlock
                                x:Name="StatusNoteText"
                                MaxWidth="1100"
                                Text="Fetching live candles and calculating strategy status."
                                TextWrapping="Wrap" />
                        </StackPanel>
                        <StackPanel
                            Grid.Column="1"
                            MinWidth="180"
                            HorizontalAlignment="Right"
                            Spacing="4">
                            <TextBlock
                                x:Name="ConfidenceText"
                                HorizontalAlignment="Right"
                                FontSize="22"
                                FontWeight="SemiBold"
                                Text="0%" />
                            <TextBlock
                                x:Name="PhaseText"
                                HorizontalAlignment="Right"
                                Text="Starting" />
                        </StackPanel>
                    </Grid>
                </Border>

                <Grid
                    Grid.Row="1"
                    HorizontalAlignment="Stretch"
                    ColumnSpacing="14">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="440" />
                    </Grid.ColumnDefinitions>

                    <Grid RowSpacing="12">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Border
                            Padding="12"
                            Background="White"
                            BorderBrush="#D6DBE3"
                            BorderThickness="1"
                            CornerRadius="8">
                            <Grid RowSpacing="10">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>
                                <Grid ColumnSpacing="10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="220" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock
                                        VerticalAlignment="Center"
                                        FontWeight="SemiBold"
                                        Text="Market" />
                                    <ComboBox
                                        x:Name="MarketComboBox"
                                        AutomationProperties.AutomationId="MarketComboBox"
                                        AutomationProperties.Name="Market"
                                        Grid.Column="1"
                                        MinWidth="190"
                                        SelectionChanged="MarketComboBox_SelectionChanged" />
                                    <Button
                                        x:Name="RefreshButton"
                                        AutomationProperties.AutomationId="RefreshLiveDataButton"
                                        AutomationProperties.Name="Refresh live market data"
                                        AccessKey="R"
                                        Grid.Column="2"
                                        Click="RefreshButton_Click"
                                        Content="Refresh" />
                                    <CheckBox
                                        x:Name="AutoRefreshCheckBox"
                                        AutomationProperties.AutomationId="AutoRefreshCheckBox"
                                        AutomationProperties.Name="Auto refresh live market data"
                                        Grid.Column="3"
                                        VerticalAlignment="Center"
                                        Content="Auto refresh"
                                        IsChecked="True" />
                                    <TextBlock
                                        x:Name="LastUpdatedText"
                                        Grid.Column="4"
                                        HorizontalAlignment="Right"
                                        VerticalAlignment="Center"
                                        Foreground="#596579"
                                        Text="Waiting for live data" />
                                </Grid>

                                <Canvas
                                    x:Name="ChartCanvas"
                                    Grid.Row="1"
                                    MinHeight="220"
                                    MinWidth="540"
                                    Background="#0E1726"
                                    RenderTransformOrigin="0.5,0.5"
                                    SizeChanged="ChartCanvas_SizeChanged">
                                    <Canvas.RenderTransform>
                                        <CompositeTransform x:Name="ChartCanvasTransform" />
                                    </Canvas.RenderTransform>
                                </Canvas>
                            </Grid>
                        </Border>

                        <Grid Grid.Row="1" ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Border
                                Padding="12"
                                Background="White"
                                BorderBrush="#D6DBE3"
                                BorderThickness="1"
                                CornerRadius="8">
                                <StackPanel Spacing="10">
                                    <TextBlock
                                        FontSize="17"
                                        FontWeight="SemiBold"
                                        Text="Live Facts" />
                                    <ScrollViewer
                                        MaxHeight="190"
                                        HorizontalScrollBarVisibility="Disabled"
                                        VerticalScrollBarVisibility="Auto">
                                        <Grid RowSpacing="8" ColumnSpacing="12">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="130" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>
                                            <TextBlock FontWeight="SemiBold" Text="Market" />
                                            <TextBlock x:Name="FactMarketText" Grid.Column="1" Text="-" />
                                            <TextBlock Grid.Row="1" FontWeight="SemiBold" Text="HTF bias" />
                                            <TextBlock x:Name="FactBiasText" Grid.Row="1" Grid.Column="1" Text="-" />
                                            <TextBlock Grid.Row="2" FontWeight="SemiBold" Text="Last close" />
                                            <TextBlock x:Name="FactCloseText" Grid.Row="2" Grid.Column="1" Text="-" />
                                            <TextBlock Grid.Row="3" FontWeight="SemiBold" Text="Last candle" />
                                            <TextBlock x:Name="FactCandleText" Grid.Row="3" Grid.Column="1" Text="-" />
                                            <TextBlock Grid.Row="4" FontWeight="SemiBold" Text="Session" />
                                            <TextBlock x:Name="FactSessionText" Grid.Row="4" Grid.Column="1" Text="-" TextWrapping="Wrap" />
                                            <TextBlock Grid.Row="5" FontWeight="SemiBold" Text="Daily" />
                                            <TextBlock x:Name="FactD1Text" Grid.Row="5" Grid.Column="1" Text="-" TextWrapping="Wrap" />
                                            <TextBlock Grid.Row="6" FontWeight="SemiBold" Text="4H" />
                                            <TextBlock x:Name="FactH4Text" Grid.Row="6" Grid.Column="1" Text="-" TextWrapping="Wrap" />
                                            <TextBlock Grid.Row="7" FontWeight="SemiBold" Text="1H" />
                                            <TextBlock x:Name="FactH1Text" Grid.Row="7" Grid.Column="1" Text="-" TextWrapping="Wrap" />
                                            <TextBlock Grid.Row="8" FontWeight="SemiBold" Text="30M" />
                                            <TextBlock x:Name="FactM30Text" Grid.Row="8" Grid.Column="1" Text="-" TextWrapping="Wrap" />
                                            <TextBlock Grid.Row="9" FontWeight="SemiBold" Text="15M" />
                                            <TextBlock x:Name="FactM15Text" Grid.Row="9" Grid.Column="1" Text="-" TextWrapping="Wrap" />
                                        </Grid>
                                    </ScrollViewer>
                                </StackPanel>
                            </Border>

                            <Border
                                Grid.Column="1"
                                Padding="12"
                                Background="White"
                                BorderBrush="#D6DBE3"
                                BorderThickness="1"
                                CornerRadius="8">
                                <StackPanel Spacing="10">
                                    <TextBlock
                                        FontSize="17"
                                        FontWeight="SemiBold"
                                        Text="Risk Plan" />
                                    <Grid RowSpacing="8" ColumnSpacing="12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="90" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                        <TextBlock FontWeight="SemiBold" Text="Entry" />
                                        <TextBlock x:Name="RiskEntryText" Grid.Column="1" Text="-" />
                                        <TextBlock Grid.Row="1" FontWeight="SemiBold" Text="Stop" />
                                        <TextBlock x:Name="RiskStopText" Grid.Row="1" Grid.Column="1" Text="-" />
                                        <TextBlock Grid.Row="2" FontWeight="SemiBold" Text="TP1" />
                                        <TextBlock x:Name="RiskTp1Text" Grid.Row="2" Grid.Column="1" Text="-" />
                                        <TextBlock Grid.Row="3" FontWeight="SemiBold" Text="TP2" />
                                        <TextBlock x:Name="RiskTp2Text" Grid.Row="3" Grid.Column="1" Text="-" />
                                        <TextBlock Grid.Row="4" FontWeight="SemiBold" Text="Structure" />
                                        <TextBlock x:Name="RiskStructureText" Grid.Row="4" Grid.Column="1" Text="-" />
                                        <TextBlock Grid.Row="5" FontWeight="SemiBold" Text="Entry type" />
                                        <TextBlock x:Name="RiskEntryModeText" Grid.Row="5" Grid.Column="1" Text="-" />
                                        <TextBlock Grid.Row="6" FontWeight="SemiBold" Text="Scale" />
                                        <TextBlock x:Name="RiskScaleText" Grid.Row="6" Grid.Column="1" Text="75-90%" />
                                        <TextBlock Grid.Row="7" FontWeight="SemiBold" Text="Note" />
                                        <TextBlock
                                            x:Name="RiskNoteText"
                                            Grid.Row="7"
                                            Grid.Column="1"
                                            Text="-"
                                            TextWrapping="Wrap" />
                                    </Grid>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Grid>

                    <Grid Grid.Column="1" RowSpacing="12">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="1.35*" />
                        </Grid.RowDefinitions>
                        <Border
                            Padding="12"
                            Background="White"
                            BorderBrush="#D6DBE3"
                            BorderThickness="1"
                            CornerRadius="8">
                            <Grid RowSpacing="10">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>
                                <TextBlock
                                    FontSize="17"
                                    FontWeight="SemiBold"
                                    Text="Strategy Checklist" />
                                <ScrollViewer
                                    Grid.Row="1"
                                    HorizontalScrollBarVisibility="Disabled"
                                    VerticalScrollBarVisibility="Auto">
                                    <ItemsControl x:Name="ChecklistItems">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate x:DataType="local:ChecklistItem">
                                                <Border
                                                    Margin="0,0,0,8"
                                                    Padding="8"
                                                    Background="#F6F8FB"
                                                    CornerRadius="6">
                                                    <Grid ColumnSpacing="8">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="52" />
                                                            <ColumnDefinition Width="*" />
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock
                                                            FontWeight="SemiBold"
                                                            Text="{x:Bind State}" />
                                                        <StackPanel Grid.Column="1">
                                                            <TextBlock FontWeight="SemiBold" Text="{x:Bind Label}" />
                                                            <TextBlock Text="{x:Bind Text}" TextWrapping="Wrap" />
                                                        </StackPanel>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                            </Grid>
                        </Border>

                        <Border
                            Grid.Row="1"
                            Padding="12"
                            Background="White"
                            BorderBrush="#D6DBE3"
                            BorderThickness="1"
                            CornerRadius="8">
                            <StackPanel Spacing="10">
                                <Grid ColumnSpacing="10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock
                                            FontSize="18"
                                            FontWeight="SemiBold"
                                            Text="OpenCode Prediction" />
                                        <TextBlock
                                            Foreground="#596579"
                                            Text="Uses opencode to think through the live structure and predict the next likely move."
                                            TextWrapping="Wrap" />
                                    </StackPanel>
                                    <Button
                                        x:Name="ThinkButton"
                                        AutomationProperties.AutomationId="ThinkButton"
                                        AutomationProperties.Name="Run OpenCode prediction"
                                        Grid.Column="1"
                                        Click="ThinkButton_Click"
                                        Content="Predict" />
                                </Grid>
                                <CheckBox
                                    x:Name="AutoThinkCheckBox"
                                    AutomationProperties.AutomationId="AutoThinkCheckBox"
                                    AutomationProperties.Name="Run OpenCode prediction automatically"
                                    HorizontalContentAlignment="Stretch"
                                    IsChecked="True">
                                    <TextBlock Text="Auto predict on first load and status changes" TextWrapping="Wrap" />
                                </CheckBox>
                                <Grid ColumnSpacing="8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <CheckBox
                                        x:Name="WindowsNotificationsCheckBox"
                                        AutomationProperties.AutomationId="WindowsNotificationsCheckBox"
                                        AutomationProperties.Name="Show Windows status notifications"
                                        VerticalAlignment="Center"
                                        HorizontalContentAlignment="Stretch"
                                        IsChecked="True">
                                        <TextBlock Text="Windows alerts on status change" TextWrapping="Wrap" />
                                    </CheckBox>
                                    <Button
                                        x:Name="TestNotificationButton"
                                        AutomationProperties.AutomationId="TestNotificationButton"
                                        AutomationProperties.Name="Test Windows notification"
                                        Grid.Column="1"
                                        Click="TestNotificationButton_Click"
                                        Content="Test" />
                                </Grid>
                                <Border
                                    x:Name="PredictionPanel"
                                    AutomationProperties.AutomationId="PredictionPanel"
                                    AutomationProperties.Name="OpenCode prediction cards"
                                    Padding="8"
                                    Background="#FFF7E0"
                                    BorderBrush="#E5B21F"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    RenderTransformOrigin="0.5,0.5">
                                    <Border.RenderTransform>
                                        <CompositeTransform x:Name="PredictionPanelTransform" />
                                    </Border.RenderTransform>
                                    <Grid RowSpacing="8">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                        <Grid ColumnSpacing="8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock
                                                x:Name="PredictionStateText"
                                                FontSize="13"
                                                FontWeight="SemiBold"
                                                Text="AI: waiting for live data"
                                                TextWrapping="Wrap" />
                                            <TextBlock
                                                x:Name="PredictionModelText"
                                                Grid.Column="1"
                                                Foreground="#596579"
                                                Text="free model auto"
                                                TextWrapping="Wrap" />
                                        </Grid>
                                        <Grid Grid.Row="1" RowSpacing="8" ColumnSpacing="8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>

                                            <Border
                                                x:Name="PredictionThinkingCard"
                                                Padding="8"
                                                Background="#FFFFFF"
                                                BorderBrush="#D6DBE3"
                                                BorderThickness="1"
                                                CornerRadius="6">
                                                <StackPanel>
                                                    <TextBlock
                                                        FontSize="11"
                                                        FontWeight="SemiBold"
                                                        Foreground="#596579"
                                                        Text="THINKING" />
                                                    <TextBlock
                                                        x:Name="PredictionThinkingText"
                                                        MaxLines="4"
                                                        Text="OpenCode will read the live structure automatically."
                                                        TextTrimming="WordEllipsis"
                                                        TextWrapping="Wrap" />
                                                </StackPanel>
                                            </Border>

                                            <Border
                                                x:Name="PredictionMoveCard"
                                                Grid.Column="1"
                                                Padding="8"
                                                Background="#FFFFFF"
                                                BorderBrush="#D6DBE3"
                                                BorderThickness="1"
                                                CornerRadius="6">
                                                <StackPanel>
                                                    <TextBlock
                                                        FontSize="11"
                                                        FontWeight="SemiBold"
                                                        Foreground="#596579"
                                                        Text="NEXT MOVE" />
                                                    <TextBlock
                                                        x:Name="PredictionMoveText"
                                                        MaxLines="4"
                                                        Text="No prediction yet."
                                                        TextTrimming="WordEllipsis"
                                                        TextWrapping="Wrap" />
                                                </StackPanel>
                                            </Border>

                                            <Border
                                                x:Name="PredictionInvalidationCard"
                                                Grid.Row="1"
                                                Padding="8"
                                                Background="#FFFFFF"
                                                BorderBrush="#D6DBE3"
                                                BorderThickness="1"
                                                CornerRadius="6">
                                                <StackPanel>
                                                    <TextBlock
                                                        FontSize="11"
                                                        FontWeight="SemiBold"
                                                        Foreground="#596579"
                                                        Text="INVALIDATION" />
                                                    <TextBlock
                                                        x:Name="PredictionInvalidationText"
                                                        MaxLines="4"
                                                        Text="Waiting for OpenCode."
                                                        TextTrimming="WordEllipsis"
                                                        TextWrapping="Wrap" />
                                                </StackPanel>
                                            </Border>

                                            <Border
                                                x:Name="PredictionFinalCard"
                                                Grid.Row="1"
                                                Grid.Column="1"
                                                Padding="8"
                                                Background="#FFFFFF"
                                                BorderBrush="#D6DBE3"
                                                BorderThickness="1"
                                                CornerRadius="6">
                                                <StackPanel>
                                                    <TextBlock
                                                        FontSize="11"
                                                        FontWeight="SemiBold"
                                                        Foreground="#596579"
                                                        Text="BOT READ" />
                                                    <TextBlock
                                                        x:Name="PredictionFinalReadText"
                                                        MaxLines="3"
                                                        Text="STATUS: LOADING"
                                                        TextTrimming="WordEllipsis"
                                                        TextWrapping="Wrap" />
                                                </StackPanel>
                                            </Border>
                                        </Grid>
                                    </Grid>
                                </Border>
                            </StackPanel>
                        </Border>

                        <Border
                            Grid.Row="2"
                            Padding="12"
                            Background="White"
                            BorderBrush="#D6DBE3"
                            BorderThickness="1"
                            CornerRadius="8">
                            <Grid RowSpacing="10">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>
                                <TextBlock
                                    FontSize="17"
                                    FontWeight="SemiBold"
                                    Text="Webhooks" />
                                <ScrollViewer
                                    Grid.Row="1"
                                    HorizontalScrollBarVisibility="Disabled"
                                    VerticalScrollBarVisibility="Auto">
                                    <StackPanel Spacing="8">
                                        <Grid ColumnSpacing="10">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <ListView
                                                x:Name="WebhookList"
                                                AutomationProperties.AutomationId="WebhookList"
                                                AutomationProperties.Name="Webhook URLs"
                                                Height="58"
                                                DisplayMemberPath="DisplayName"
                                                SelectionChanged="WebhookList_SelectionChanged" />
                                            <StackPanel Grid.Column="1" Spacing="6">
                                                <Button
                                                    AutomationProperties.AutomationId="AddWebhookButton"
                                                    AutomationProperties.Name="Add webhook URL"
                                                    Click="AddWebhookButton_Click"
                                                    Content="Add" />
                                                <Button
                                                    AutomationProperties.AutomationId="SaveWebhookButton"
                                                    AutomationProperties.Name="Save webhook URL"
                                                    Click="SaveWebhookButton_Click"
                                                    Content="Save" />
                                                <Button
                                                    AutomationProperties.AutomationId="RemoveWebhookButton"
                                                    AutomationProperties.Name="Remove webhook URL"
                                                    Click="RemoveWebhookButton_Click"
                                                    Content="Remove" />
                                                <Button
                                                    AutomationProperties.AutomationId="SendWebhookButton"
                                                    AutomationProperties.Name="Send selected webhook"
                                                    Click="SendWebhookButton_Click"
                                                    Content="Send" />
                                            </StackPanel>
                                        </Grid>

                                        <Grid RowSpacing="7" ColumnSpacing="8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="110" />
                                            </Grid.ColumnDefinitions>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>
                                            <TextBox
                                                x:Name="WebhookNameTextBox"
                                                AutomationProperties.AutomationId="WebhookNameTextBox"
                                                AutomationProperties.Name="Webhook name"
                                                Header="Name"
                                                PlaceholderText="Main alert" />
                                            <ComboBox
                                                x:Name="WebhookMethodComboBox"
                                                AutomationProperties.AutomationId="WebhookMethodComboBox"
                                                AutomationProperties.Name="Webhook method"
                                                Grid.Column="1"
                                                Header="Method" />
                                            <TextBox
                                                x:Name="WebhookUrlTextBox"
                                                AutomationProperties.AutomationId="WebhookUrlTextBox"
                                                AutomationProperties.Name="Webhook URL"
                                                Grid.Row="1"
                                                Grid.ColumnSpan="2"
                                                Header="URL"
                                                PlaceholderText="Webhook URL" />
                                            <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="16">
                                                <CheckBox
                                                    x:Name="WebhookEnabledCheckBox"
                                                    AutomationProperties.AutomationId="WebhookEnabledCheckBox"
                                                    AutomationProperties.Name="Webhook enabled"
                                                    Content="Enabled"
                                                    IsChecked="True" />
                                                <CheckBox
                                                    x:Name="WebhookOnStatusChangeCheckBox"
                                                    AutomationProperties.AutomationId="WebhookOnStatusChangeCheckBox"
                                                    AutomationProperties.Name="Send webhook when status changes"
                                                    HorizontalContentAlignment="Stretch">
                                                    <TextBlock Text="Send when status changes" TextWrapping="Wrap" />
                                                </CheckBox>
                                            </StackPanel>
                                        </Grid>

                                        <TextBlock FontWeight="SemiBold" Text="Headers" />
                                        <Grid ColumnSpacing="8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <TextBox
                                                x:Name="HeaderKeyTextBox"
                                                AutomationProperties.AutomationId="HeaderKeyTextBox"
                                                AutomationProperties.Name="Header name"
                                                PlaceholderText="Header name" />
                                            <TextBox
                                                x:Name="HeaderValueTextBox"
                                                AutomationProperties.AutomationId="HeaderValueTextBox"
                                                AutomationProperties.Name="Header value"
                                                Grid.Column="1"
                                                PlaceholderText="Header value" />
                                            <Button
                                                AutomationProperties.AutomationId="AddHeaderButton"
                                                AutomationProperties.Name="Add webhook header"
                                                Grid.Column="2"
                                                Click="AddHeaderButton_Click"
                                                Content="Add" />
                                        </Grid>
                                        <ListView
                                            x:Name="HeadersList"
                                            AutomationProperties.AutomationId="HeadersList"
                                            AutomationProperties.Name="Webhook headers"
                                            Height="34"
                                            DisplayMemberPath="DisplayText" />

                                        <TextBlock FontWeight="SemiBold" Text="Values" />
                                        <Grid ColumnSpacing="8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <TextBox
                                                x:Name="ValueKeyTextBox"
                                                AutomationProperties.AutomationId="ValueKeyTextBox"
                                                AutomationProperties.Name="Value name"
                                                PlaceholderText="Value name" />
                                            <TextBox
                                                x:Name="ValueValueTextBox"
                                                AutomationProperties.AutomationId="ValueValueTextBox"
                                                AutomationProperties.Name="Value"
                                                Grid.Column="1"
                                                PlaceholderText="Value" />
                                            <Button
                                                AutomationProperties.AutomationId="AddValueButton"
                                                AutomationProperties.Name="Add webhook value"
                                                Grid.Column="2"
                                                Click="AddValueButton_Click"
                                                Content="Add" />
                                        </Grid>
                                        <ListView
                                            x:Name="ValuesList"
                                            AutomationProperties.AutomationId="ValuesList"
                                            AutomationProperties.Name="Webhook values"
                                            Height="34"
                                            DisplayMemberPath="DisplayText" />

                                        <TextBox
                                            x:Name="WebhookLogTextBox"
                                            AutomationProperties.AutomationId="WebhookLogTextBox"
                                            AutomationProperties.Name="Webhook log"
                                            Height="52"
                                            Header="Webhook log"
                                            IsReadOnly="True"
                                            TextWrapping="Wrap" />
                                    </StackPanel>
                                </ScrollViewer>
                            </Grid>
                        </Border>
                    </Grid>
                </Grid>

        <Border
            x:Name="StatusFlashOverlay"
            Grid.RowSpan="2"
            Background="#E5B21F"
            IsHitTestVisible="False"
            Opacity="0"
            RenderTransformOrigin="0.5,0.5">
            <Border.RenderTransform>
                <CompositeTransform x:Name="StatusFlashTransform" />
            </Border.RenderTransform>
        </Border>
    </Grid>
</Page>
