// Chamilleia Supply & Demand — High-Probability Setup Highlighter
// -----------------------------------------------------------------
// Implements the core 4-step Supply & Demand rules:
//   1. Market-structure direction (bullish / bearish)
//   2. Break of Structure (BOS) confirmation (body OR wick valid)
//   3. Most-recent demand/supply zone (recency rule, drawn wick-to-wick)
//   4. Zone tap alerts + entry guidance
//
// Extras:
//   - Minor Break of Structure (mBOS) "stair-step" reversal confirmation,
//     confirmed by a second lower high (sells) / second higher low (buys).
//   - Zone invalidation when a candle BODY closes through the zone.
//   - A+ flag when price only wicks into the zone (no body close inside).
//
// Designed for the 5-minute execution timeframe described in the plan.

//@version=5
indicator("Chamilleia Supply & Demand", shorttitle="CHAM S&D", overlay=true, max_boxes_count=500, max_lines_count=500, max_labels_count=500)

// ─────────────────────────── Inputs ───────────────────────────
grpStruct   = "Structure"
pivotLen    = input.int(5,  "Pivot lookback (structure swing strength)", minval=1, group=grpStruct)

grpZone     = "Zones"
impulseMult = input.float(1.5, "Impulse strength (x avg range) to validate a push", minval=0.5, step=0.1, group=grpZone)
extendBars  = input.int(60, "Zone extension (bars to the right)", minval=5, group=grpZone)

grpRisk     = "Risk"
maxSlPoints = input.float(50, "Max stop-loss size (points) before tightening", minval=0, group=grpRisk)

grpSession  = "Session Gate"
london      = input.session("0300-1200", "London session", group=grpSession)
newyork     = input.session("0930-1600", "New York session", group=grpSession)

grpTopDown  = "Top-Down Gate"
confirm15   = input.timeframe("15", "15M confirmation", group=grpTopDown)
confirm30   = input.timeframe("30", "30M confirmation", group=grpTopDown)

grpStyle    = "Style"
demandCol   = input.color(color.new(color.teal, 80), "Demand zone fill", group=grpStyle)
supplyCol   = input.color(color.new(color.red, 80),  "Supply zone fill", group=grpStyle)
borderDem   = input.color(color.teal, "Demand border", group=grpStyle)
borderSup   = input.color(color.red,  "Supply border", group=grpStyle)
showLabels  = input.bool(true, "Show BOS / tap labels", group=grpStyle)
showStatus  = input.bool(true, "Show automatic Status label", group=grpStyle)

// ─────────────────────── Market structure direction ───────────────────────
// Market direction is price action only. No EMA or indicator filter is used.
var string structureDir = "neutral"
bool bull = false
bool bear = false

// ─────────────────────── Swing structure ───────────────────────
ph = ta.pivothigh(high, pivotLen, pivotLen)
pl = ta.pivotlow(low,  pivotLen, pivotLen)

var float lastSwingHigh = na
var float lastSwingLow  = na
if not na(ph)
    lastSwingHigh := ph
if not na(pl)
    lastSwingLow := pl

// Break of Structure: close/high beyond the most recent swing high (buys),
// or close/low beyond the most recent swing low (sells). Wick OR body valid.
bosUp   = not na(lastSwingHigh) and high > lastSwingHigh and high[1] <= lastSwingHigh
bosDown = not na(lastSwingLow)  and low  < lastSwingLow  and low[1]  >= lastSwingLow
if bosUp
    structureDir := "bullish"
if bosDown
    structureDir := "bearish"
bull := structureDir == "bullish"
bear := structureDir == "bearish"

// ─────────────────────── Impulse / push ───────────────────────
rng     = high - low
avgRng  = ta.sma(rng, 20)
strongUp   = close > open and rng > avgRng * impulseMult
strongDown = close < open and rng > avgRng * impulseMult

// ─────────────────────── Zone storage ───────────────────────
// A zone = the most recent opposite-color candle before an aggressive push,
// drawn from the top of the wick to the bottom of the wick.
type Zone
    box  bx
    float top
    float bot
    bool  isDemand
    bool  invalidated
    bool  tapped
    bool  bodyEntered

var array<Zone> zones = array.new<Zone>()

// Find the most recent opposite candle before this impulse bar.
// For a demand zone: most recent red (close<open) candle in the lookback window.
// For a supply zone: most recent green (close>open) candle.
f_lastOpposite(bool wantRed) =>
    float t = na
    float b = na
    int found = -1
    for i = 1 to 10
        bool red   = close[i] < open[i]
        bool green = close[i] > open[i]
        if (wantRed and red) or (not wantRed and green)
            found := i
            break
    if found >= 0
        t := high[found]
        b := low[found]
    [t, b]

f_addZone(bool isDemand) =>
    [t, b] = f_lastOpposite(isDemand)  // demand wants a red base candle; supply wants green
    if not na(t)
        box bx = box.new(bar_index, t, bar_index + extendBars, b, border_color=isDemand ? borderDem : borderSup, bgcolor=isDemand ? demandCol : supplyCol, border_width=1)
        Zone z = Zone.new(bx, t, b, isDemand, false, false, false)
        array.unshift(zones, z)
        // Recency rule: keep only the newest zone from the latest structure break.
        while array.size(zones) > 1
            Zone old = array.pop(zones)
            box.delete(old.bx)

// Create a fresh zone only when BOS confirms trend continuation + impulse present.
if bosUp and bull and strongUp
    f_addZone(true)
    if showLabels
        label.new(bar_index, high, "BOS ▲", style=label.style_label_down, color=color.new(borderDem, 0), textcolor=color.white, size=size.tiny)

if bosDown and bear and strongDown
    f_addZone(false)
    if showLabels
        label.new(bar_index, low, "BOS ▼", style=label.style_label_up, color=color.new(borderSup, 0), textcolor=color.white, size=size.tiny)

// ─────────────── Zone maintenance: extend, tap, invalidate ───────────────
var float lastTapTop = na
var float lastTapBot = na
var bool  lastTapDem = na
var bool  lastTapWickOnlyNoBody = false

if array.size(zones) > 0
    for i = 0 to array.size(zones) - 1
        Zone z = array.get(zones, i)
        if not z.invalidated
            box.set_right(z.bx, bar_index + extendBars)
            float bodyTop = math.max(open, close)
            float bodyBot = math.min(open, close)
            bool bodyTouchesZone = bodyBot <= z.top and bodyTop >= z.bot
            bool wickOnlyTap = z.isDemand ? low <= z.top and bodyBot > z.top : high >= z.bot and bodyTop < z.bot
            // Tap: price trades into the zone.
            bool tappedNow = low <= z.top and high >= z.bot
            if tappedNow and not z.tapped
                z.tapped := true
                lastTapTop := z.top
                lastTapBot := z.bot
                lastTapDem := z.isDemand
                lastTapWickOnlyNoBody := wickOnlyTap and not z.bodyEntered
                if showLabels
                    label.new(bar_index, z.isDemand ? z.bot : z.top, z.isDemand ? "TAP ▲" : "TAP ▼", style=z.isDemand ? label.style_label_up : label.style_label_down, color=color.new(color.gray, 20), textcolor=color.white, size=size.tiny)
            if bodyTouchesZone
                z.bodyEntered := true
            // Invalidation: a candle BODY closes through the zone.
            bool bodyThrough = z.isDemand ? close < z.bot : close > z.top
            if bodyThrough
                z.invalidated := true
                if lastTapTop == z.top and lastTapBot == z.bot and lastTapDem == z.isDemand
                    lastTapWickOnlyNoBody := false
                box.set_bgcolor(z.bx, color.new(color.gray, 90))
                box.set_border_style(z.bx, line.style_dashed)

// ─────────────── Entry trigger (Break-of-Candle entry) ───────────────
// After a candle taps a valid demand zone and closes, a buy triggers when the
// next candle breaks the high of that tap candle (mirror for sells).
demandTapClose = not na(lastTapDem) and lastTapDem and low[1] <= lastTapTop and low[1] >= lastTapBot
supplyTapClose = not na(lastTapDem) and not lastTapDem and high[1] <= lastTapTop and high[1] >= lastTapBot

buyTrigger  = demandTapClose and high > high[1] and bull
sellTrigger = supplyTapClose and low  < low[1]  and bear

// Gate entries by the documented high-volume sessions and 15M/30M confirmation.
inLondon = not na(time(timeframe.period, london))
inNewYork = not na(time(timeframe.period, newyork))
sessionOk = inLondon or inNewYork
dir15 = request.security(syminfo.tickerid, confirm15, structureDir, lookahead=barmerge.lookahead_off)
dir30 = request.security(syminfo.tickerid, confirm30, structureDir, lookahead=barmerge.lookahead_off)
lowerTimeframesOppose = (bull and (dir15 == "bearish" or dir30 == "bearish")) or (bear and (dir15 == "bullish" or dir30 == "bullish"))

buyReady = buyTrigger and sessionOk and not lowerTimeframesOppose
sellReady = sellTrigger and sessionOk and not lowerTimeframesOppose
buySessionBlocked = buyTrigger and not sessionOk
sellSessionBlocked = sellTrigger and not sessionOk
buyConfirmBlocked = buyTrigger and sessionOk and lowerTimeframesOppose
sellConfirmBlocked = sellTrigger and sessionOk and lowerTimeframesOppose

plotshape(buyReady,  title="Buy entry",  style=shape.triangleup,   location=location.belowbar, color=color.teal, size=size.small, text="BUY")
plotshape(sellReady, title="Sell entry", style=shape.triangledown, location=location.abovebar, color=color.red,  size=size.small, text="SELL")
plotshape(buySessionBlocked or sellSessionBlocked, title="Session-gated entry", style=shape.circle, location=location.top, color=color.orange, size=size.tiny, text="SESSION")
plotshape(buyConfirmBlocked or sellConfirmBlocked, title="Top-down-gated entry", style=shape.circle, location=location.top, color=color.yellow, size=size.tiny, text="CONF")

// ─────────────── A+ flag: wick-only into zone, no body close inside ───────────────
aPlusBuy  = buyReady  and open >= lastTapTop and lastTapWickOnlyNoBody  // wick only, no body inside zone
aPlusSell = sellReady and open <= lastTapBot and lastTapWickOnlyNoBody  // wick only, no body inside zone
plotchar(aPlusBuy or aPlusSell, title="A+ setup", char="★", location=location.top, color=color.yellow, size=size.tiny)

// ─────────────── Minor BOS (stair-step) reversal confirmation ───────────────
// Confirmed by a second lower high (for sells) / second higher low (for buys).
var float lh1 = na
var float lh2 = na
var float hl1 = na
var float hl2 = na
if not na(ph)
    lh2 := lh1
    lh1 := ph
if not na(pl)
    hl2 := hl1
    hl1 := pl

secondLowerHigh  = not na(lh1) and not na(lh2) and lh1 < lh2   // bearish mBOS confirmation
secondHigherLow  = not na(hl1) and not na(hl2) and hl1 > hl2   // bullish mBOS confirmation

plotshape(secondLowerHigh,  title="2nd Lower High (mBOS sell confirm)",  style=shape.xcross, location=location.abovebar, color=color.maroon, size=size.tiny)
plotshape(secondHigherLow,  title="2nd Higher Low (mBOS buy confirm)",   style=shape.cross,  location=location.belowbar, color=color.green,  size=size.tiny)

// Status table: plain-language Buy / Sell / Wait readout for the latest bar.
string statusText = buyReady ? (aPlusBuy ? "STATUS: A+ BUY" : "STATUS: BUY") : sellReady ? (aPlusSell ? "STATUS: A+ SELL" : "STATUS: SELL") : (buySessionBlocked ? "STATUS: WAIT SESSION BUY" : sellSessionBlocked ? "STATUS: WAIT SESSION SELL" : buyConfirmBlocked ? "STATUS: WAIT CONFIRM BUY" : sellConfirmBlocked ? "STATUS: WAIT CONFIRM SELL" : bull ? "STATUS: WAIT FOR BUY" : bear ? "STATUS: WAIT FOR SELL" : "STATUS: NO TRADE")
string statusNote = buyReady or sellReady ? "Entry trigger passed session and 15M/30M confirmation. Check stop and risk." : buySessionBlocked or sellSessionBlocked ? "Entry trigger formed outside London/New York volume." : buyConfirmBlocked or sellConfirmBlocked ? "Entry trigger formed, but 15M/30M still oppose the active bias." : bull ? "Structure is bullish. Wait for zone tap plus trigger." : bear ? "Structure is bearish. Wait for zone tap plus trigger." : "No clear structure. Stand aside."
color statusBg = buyReady ? color.teal : sellReady ? color.red : (buySessionBlocked or sellSessionBlocked or buyConfirmBlocked or sellConfirmBlocked or bull or bear) ? color.orange : color.gray

var table statusTable = table.new(position.top_right, 1, 2, border_width=1)
if showStatus and barstate.islast
    table.cell(statusTable, 0, 0, statusText, text_color=color.white, bgcolor=statusBg, text_size=size.large)
    table.cell(statusTable, 0, 1, statusNote, text_color=color.white, bgcolor=color.new(statusBg, 35), text_size=size.small)
if not showStatus and barstate.islast
    table.clear(statusTable, 0, 0, 0, 1)

// ─────────────────────────── Alerts ───────────────────────────
alertcondition(buyReady,          title="Buy Entry Triggered",  message="CHAM S&D: BUY entry on {{ticker}} {{interval}}")
alertcondition(sellReady,         title="Sell Entry Triggered", message="CHAM S&D: SELL entry on {{ticker}} {{interval}}")
alertcondition(buySessionBlocked or sellSessionBlocked, title="Session Gate", message="CHAM S&D: Entry trigger formed outside London/New York session on {{ticker}}")
alertcondition(buyConfirmBlocked or sellConfirmBlocked, title="Top-Down Gate", message="CHAM S&D: Entry trigger waits for 15M/30M confirmation on {{ticker}}")
alertcondition(bosUp,             title="Bullish BOS",          message="CHAM S&D: Bullish Break of Structure on {{ticker}}")
alertcondition(bosDown,           title="Bearish BOS",          message="CHAM S&D: Bearish Break of Structure on {{ticker}}")
alertcondition(secondLowerHigh,   title="2nd Lower High",       message="CHAM S&D: Second lower high — bearish mBOS confirmation")
alertcondition(secondHigherLow,   title="2nd Higher Low",       message="CHAM S&D: Second higher low — bullish mBOS confirmation")
